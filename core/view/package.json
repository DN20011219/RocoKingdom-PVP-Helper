{
  "name": "rk-world-view",
  "version": "0.2.0",
  "description": "RocoKingdom World OCR - React view (frameless)",
  "main": "main.js",
  "scripts": {
    "dev:react": "vite",
    "dev:electron": "cross-env ELECTRON_DEV=true wait-on http://localhost:5173 && electron .",
    "dev": "concurrently -k \"npm run dev:react -- --host 127.0.0.1\" \"npm run dev:electron\"",
    "start": "npm run build:react && electron .",
    "electron:download:cn": "cross-env ELECTRON_MIRROR=https://npmmirror.com/mirrors/electron/ node node_modules/electron/install.js",
    "build:react": "vite build",
    "build:electron": "electron-packager . rk-world-view --platform=win32 --arch=x64 --out=dist --overwrite",
    "pack-win": "npm run build:react && npm run build:electron"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^8.2.0",
    "cross-env": "^7.0.3",
    "electron": "^42.1.0",
    "electron-packager": "^17.1.1",
    "vite": "^8.0.13",
    "wait-on": "^7.0.1"
  }
}
